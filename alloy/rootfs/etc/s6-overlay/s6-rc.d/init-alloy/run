#!/usr/bin/with-contenv bash
# shellcheck shell=bash
set -euo pipefail

CONFIG_DIR=/etc/alloy
CONFIG_FILE=${CONFIG_DIR}/config.alloy
OPTIONS_FILE=/data/options.json
RENDERER=/usr/local/bin/render-alloy-config

mkdir -p "${CONFIG_DIR}" /data/alloy

JOURNAL_PATH=''
for candidate in /var/log/journal /run/log/journal; do
    if [[ -d "${candidate}" && -n "$(ls -A "${candidate}" 2>/dev/null)" ]]; then
        JOURNAL_PATH=${candidate}
        break
    fi
done

if [[ -z "${JOURNAL_PATH}" ]]; then
    echo "No populated systemd journal directory is available" >&2
    exit 1
fi

CONFIG_TMP=$(mktemp "${CONFIG_FILE}.XXXXXX")
cleanup() {
    rm -f "${CONFIG_TMP}"
}
trap cleanup EXIT

echo "-----------------------------------------------------------"
echo " Grafana Alloy for Home Assistant"
echo " Journal path: ${JOURNAL_PATH}"

"${RENDERER}" "${OPTIONS_FILE}" "${CONFIG_TMP}" "${JOURNAL_PATH}"

echo "Validating generated Alloy configuration"
/usr/bin/alloy validate "${CONFIG_TMP}"

mv "${CONFIG_TMP}" "${CONFIG_FILE}"
chmod 0600 "${CONFIG_FILE}"
trap - EXIT

echo " Alloy configuration validated"
echo "-----------------------------------------------------------"
